<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>9Anime</title>

    <link rel="stylesheet"  href="styles/main.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous">
</head>
<body class="bg-dark text-white">

<div class="container"> 
    <header class="d-flex flex-wrap justify-content-center py-3 mb-4 border-bottom"> 
        <img src="images/logo.png" alt="9Anime Logo" class="d-flex align-items-center mb-3 mb-md-0 me-md-auto link-body-emphasis text-decoration-none"> 
        <ul class="nav nav-pills"> 
            <li class="nav-item"><a href="/home" class="nav-link" style="background-color: rgb(243, 8, 235); color: white;" aria-current="page">Home</a></li>  
            <li class="nav-item"><a href="/about" class="nav-link" style= "color: rgb(243, 8, 235)" >About</a></li> 
        </ul> 
    </header> 
</div>

<div class="container col-xxl-8 px-4 py-5"> 
    <div class="row flex-lg-row-reverse align-items-center g-5 py-5"> 
        <div class="col-10 col-sm-8 col-lg-6"> 
            <img src="<%= image %>" class="d-block mx-lg-auto img-fluid" alt="Anime Artwork" width="700" height="500" loading="lazy"> 
        </div> 
        <div class="col-lg-6"> 
            <h1>Welcome to <img src="images/logo.png" alt="Logo"></h1>
            <h2 class="anime">Anime Quote</h2>

            <% if (locals.quote) { %>
                <p class="lead quote"><strong>"<%= quote %>"</strong></p>
            <% } else { %>
                <p class="lead quote"><strong>"Anime is not just a genre, it's a way of life."</strong></p>
            <% } %>

            <% if (locals.character) { %>
                <p class="lead name"><strong>— <%= character %></strong></p>
            <% } else { %>
                <p class="lead name"><strong>— Tobenna from Naruto</strong></p>
            <% } %>

            <% if (locals.animename) { %>
                <p class="lead name"><em>(<%= animename %>)</em></p>
            <% } %>

        </div> 
    </div> 
</div>

<div class="container px-4 py-5" id="custom-cards">
  <h2 class="pb-2 border-bottom text-white">Top 10 Animes</h2>

  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 py-4">
    <% if (Array.isArray(anime) && anime.length > 0) { %>
      <% anime.forEach(anime => { %>
        <div class="col d-flex align-items-center">
          <div class="card h-100 shadow-sm rounded-4 overflow-hidden bg-dark text-white" style="width: 370px;">
            <a href="/view/<%= anime.id %>">
              <img src="<%= anime.image_url %>" class="card-img-top" alt="Cover Image" style="height: 300px;  object-fit: cover;">
            </a>
            <div class="card-body d-flex flex-column p-4">
              <h3 class="mb-3 fw-bold"><%= anime.title %> (<%= anime.year %>)</h3>
              
              <div class="mb-2">
                <span class="badge bg-info text-dark"><%= anime.rating || 'N/A' %></span>
              </div>
              <div class="mb-2">
                <span class="badge bg-warning text-dark"><%= anime.status %></span>
              </div>
              <div class="mb-2">
                <span class="badge bg-info text-dark"><%= anime.episodes %> episodes</span>
              </div>
              <div class="mb-2">
                <span class="badge bg-warning text-dark"><%= anime.type %></span>
              </div>
              
              <div class="mt-auto text-center">
                
                <a href="/view/<%= anime.id %>" class="btn  mt-3 " style="background-color: rgb(243, 8, 235); color: white;">View Details</a>
              </div>
            </div>
          </div>
        </div>
      <% }); %>
    <% } else { %>
      <p class="text-white">No anime found.</p>
    <% } %>
  </div>
</div>

<div class="container px-4 py-5" id="custom-cards">
  <h2 class="pb-2 border-bottom text-white">Upcoming Anime Seasons</h2>

  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 py-4">
    <% if (Array.isArray(season) && season.length > 0) { %>
      <% season.forEach(season => { %>
        <div class="col d-flex align-items-center">
          <div class="card h-100 shadow-sm rounded-4 overflow-hidden bg-dark text-white" style="width: 370px;">
            <a href="/view/<%= season.id %>">
              <img src="<%= season.image_url %>" class="card-img-top" alt="Cover Image" style="height: 300px;  object-fit: cover;">
            </a>
            <div class="card-body d-flex flex-column p-4">
              <h3 class="mb-3 fw-bold"><%= season.title %> (<%= season.year %>)</h3>
              <div class="mb-2">
                <span class="badge bg-danger text-dark"> Release date: <span style="color:white"><%= season.day %> / <%= season.month %> / <%= season.year %></span></span>
              </div>
              <div class="mb-2">
                <span class="badge bg-info text-dark"><%= season.rating || 'N/A' %></span>
              </div>
              <div class="mb-2">
                <span class="badge bg-warning text-dark"><%= season.status %></span>
              </div>
              <div class="mb-2">
                <span class="badge bg-info text-dark"><%= season.episodes %> episodes</span>
              </div>
              <div class="mb-2">
                <span class="badge bg-warning text-dark"><%= season.type %></span>
              </div>
              
              <div class="mt-auto text-center">
                
                <a href="/viewseason/<%= season.id %>" class="btn  mt-3 " style="background-color: rgb(243, 8, 235); color: white;">View Details</a>
              </div>
            </div>
          </div>
        </div>
      <% }); %>
    <% } else { %>
      <p class="text-white">No anime found.</p>
    <% } %>
  </div>
</div>

</body>
</html>
